{{#> layouts/main}}
<div class="card" style="margin-top:16px;">
    <h2 class="table-title" title="Manage network file share connections">Connections
        <button class="icon-btn-sm" id="conn-refresh-btn" title="Refresh" style="margin-left:8px; color:#5d4037; vertical-align:middle;">
            <span class="material-icons">refresh</span>
        </button>
    </h2>
    <div id="conn-list" style="max-height:calc(66vh - 120px); overflow-y:auto;">
        <p class="empty-state">Loading...</p>
    </div>
</div>

<div class="card" style="margin-top:16px;">
    <h2 class="table-title">Add Connection</h2>
    <form id="conn-add-form" class="conn-form">
        <div style="margin-bottom:12px;">
            <label class="form-label" for="conn-type">Type</label>
            <select class="form-input" id="conn-type" name="type" style="width:auto;min-width:140px;">
                <option value="smb">SMB</option>
                <option value="sftp">SFTP</option>
            </select>
        </div>
        <div class="conn-form-grid" id="conn-fields"></div>
        <button type="submit" class="btn" style="margin-top:12px;">
            <span class="material-icons btn-icon">add</span> Add Connection
        </button>
    </form>
</div>

<!-- Edit dialog -->
<div class="face-dialog-backdrop" id="conn-dialog-backdrop" style="display:none;">
    <div class="face-dialog">
        <button class="dup-overlay-close" id="conn-dialog-close" aria-label="Close">
            <span class="material-icons">close</span>
        </button>
        <h2 class="face-dialog-title">Edit Connection</h2>
        <form id="conn-edit-form" class="face-edit-form"></form>
        <div class="face-dialog-actions">
            <button type="button" class="btn btn-sm" id="conn-save-btn">Save</button>
            <button type="button" class="btn btn-sm" id="conn-cancel-btn" style="background:#efebe9;color:#5d4037;">Cancel</button>
        </div>
    </div>
</div>

<script src="/js/connections.js"></script>
{{/layouts/main}}
