<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{appName}} — {{title}}</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap">
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Top app bar -->
    <header class="app-bar">
        <button class="icon-button" id="menu-toggle" aria-label="Toggle menu">
            <span class="material-icons">menu</span>
        </button>
        <span class="app-bar-title">{{appName}}</span>
        <span class="app-bar-spacer"></span>
        <!-- Search widget -->
        <div class="appbar-search" id="appbar-search">
            <button class="icon-button appbar-search-btn" id="search-toggle" aria-label="Search">
                <span class="material-icons">search</span>
            </button>
            <input type="text" class="appbar-search-input" id="search-input"
                   placeholder="Search..." aria-label="Search" autocomplete="off">
        </div>
        {{#if user}}
        <span class="user-info">
            <span class="material-icons">person</span>
            {{user}}
            <a href="/logout">Sign out</a>
        </span>
        {{/if}}
    </header>

    <div class="app-layout">
        <!-- Collapsible side navigation -->
        <nav class="sidebar" id="sidebar" aria-label="Main navigation">
            <ul class="nav-list">
                <li>
                    <a href="/" class="nav-item{{#if isHome}} active{{/if}}">
                        <span class="material-icons">home</span>
                        <span class="nav-label">Home</span>
                    </a>
                </li>
                <li>
                    <a href="/faces" class="nav-item{{#if isFaces}} active{{/if}}">
                        <span class="material-icons">face</span>
                        <span class="nav-label">Faces</span>
                    </a>
                </li>
                <li>
                    <a href="/connections" class="nav-item{{#if isConnections}} active{{/if}}">
                        <span class="material-icons">lan</span>
                        <span class="nav-label">Connections</span>
                    </a>
                </li>
            </ul>
            <ul class="nav-list" id="search-results-nav" style="display:none;">
                <li>
                    <a href="/search" class="nav-item" id="search-results-link">
                        <span class="material-icons">manage_search</span>
                        <span class="nav-label">Search Results</span>
                    </a>
                </li>
            </ul>
            <ul class="nav-list nav-list-bottom">
                <li>
                    <a href="/settings" class="nav-item{{#if isSettings}} active{{/if}}">
                        <span class="material-icons">settings</span>
                        <span class="nav-label">Settings</span>
                    </a>
                </li>
                <li>
                    <a href="/about" class="nav-item{{#if isAbout}} active{{/if}}">
                        <span class="material-icons">info</span>
                        <span class="nav-label">About</span>
                    </a>
                </li>
            </ul>
        </nav>

        <!-- Main content area -->
        <main class="content" id="content">
            {{> @partial-block}}
        </main>
    </div>

    <script src="/js/app.js"></script>
</body>
</html>
