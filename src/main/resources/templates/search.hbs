{{#> layouts/main}}
<div class="card">
    <h1>Search</h1>
    <form class="search-form" action="/search" method="get">
        <div class="search-field">
            <span class="material-icons search-icon">search</span>
            <input type="text" name="q" placeholder="Search..." value="{{query}}" autocomplete="off" aria-label="Search">
        </div>
        <button type="submit" class="btn">Search</button>
        <button type="button" class="btn btn-sm" id="clear-search-btn" style="margin-left:8px; background:#efebe9; color:#5d4037;">
            <span class="material-icons btn-icon">close</span> Clear
        </button>
    </form>
</div>

<div class="card" style="margin-top: 24px;">
    <h2 class="table-title">Results</h2>
    <div class="table-wrap">
        <table class="data-table" aria-label="Search results">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Location</th>
                    <th>Date Added</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                {{#each results}}
                <tr>
                    <td>{{name}}</td>
                    <td>{{category}}</td>
                    <td>{{location}}</td>
                    <td>{{dateAdded}}</td>
                    <td><span class="status-chip status-{{statusClass}}">{{status}}</span></td>
                </tr>
                {{else}}
                <tr>
                    <td colspan="5" class="empty-state">No results found.</td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>
{{/layouts/main}}
